# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/taskflow?schema=public"

# JWT (use long random strings — min 32 characters)
ACCESS_TOKEN_SECRET=your_super_secret_access_token_key_min_32_chars_here
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_different_from_above

# JWT Expiry
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:3000
